{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Lavder Enterprise design tokens — W3C DTCG format. Single source of truth for the entire brand system. Generate platform tokens from this file.",

  "color": {
    "ink": {
      "$value": "#111113",
      "$type": "color",
      "$description": "Primary near-black. Dominates the system. Use for text, UI elements, primary surfaces in dark mode."
    },
    "ink-pure": {
      "$value": "#000000",
      "$type": "color",
      "$description": "True black. Reserved for high-contrast print, absolute borders, icons on pure white."
    },
    "surface": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "Default light surface. Paired with ink."
    },
    "brand": {
      "$value": "#F87016",
      "$type": "color",
      "$description": "Lavder orange. The single brand color. Use sparingly — accent, CTA, active state."
    },
    "brand-accent": {
      "$value": "#FCA400",
      "$type": "color",
      "$description": "Lighter warm orange. Secondary brand tint. Highlights, gradients, hover states paired with brand."
    },
    "brand-dark": {
      "$value": "#D05A0E",
      "$type": "color",
      "$description": "Darker orange. Pressed/active state for interactive elements on light surfaces."
    },
    "neutral": {
      "50":  { "$value": "#FAFAFA", "$type": "color" },
      "100": { "$value": "#F4F4F5", "$type": "color" },
      "200": { "$value": "#E4E4E7", "$type": "color" },
      "300": { "$value": "#D4D4D8", "$type": "color" },
      "400": { "$value": "#A1A1AA", "$type": "color" },
      "500": { "$value": "#71717A", "$type": "color" },
      "600": { "$value": "#52525B", "$type": "color" },
      "700": { "$value": "#3F3F46", "$type": "color" },
      "800": { "$value": "#27272A", "$type": "color" },
      "900": { "$value": "#18181B", "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "#22C55E", "$type": "color" },
      "warning": { "$value": "#EAB308", "$type": "color" },
      "error":   { "$value": "#EF4444", "$type": "color" },
      "info":    { "$value": "#3B82F6", "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "{color.ink}",          "$type": "color" },
      "secondary": { "$value": "{color.neutral.600}",  "$type": "color" },
      "muted":     { "$value": "{color.neutral.500}",  "$type": "color" },
      "inverse":   { "$value": "{color.surface}",      "$type": "color" },
      "brand":     { "$value": "{color.brand}",        "$type": "color" }
    },
    "border": {
      "subtle":  { "$value": "{color.neutral.200}", "$type": "color" },
      "default": { "$value": "{color.neutral.300}", "$type": "color" },
      "strong":  { "$value": "{color.ink}",         "$type": "color" },
      "brand":   { "$value": "{color.brand}",       "$type": "color" }
    }
  },

  "gradient": {
    "brand": {
      "$value": "linear-gradient(135deg, {color.brand} 0%, {color.brand-accent} 100%)",
      "$type": "gradient",
      "$description": "Primary brand gradient. Orange to amber. Use for hero accents, highlights."
    },
    "ink": {
      "$value": "linear-gradient(180deg, {color.ink} 0%, #000000 100%)",
      "$type": "gradient",
      "$description": "Subtle depth on ink backgrounds."
    }
  },

  "font": {
    "heading": {
      "$value": "\"TWK Lausanne\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "$type": "fontFamily",
      "$description": "TWK Lausanne (Dinamo). Headings, display, marketing. Licensed — not shipped to production as webfont without license check."
    },
    "body": {
      "$value": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
      "$type": "fontFamily",
      "$description": "Inter. Body, UI, everything non-display."
    },
    "mono": {
      "$value": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", monospace",
      "$type": "fontFamily",
      "$description": "System monospace. Code, figures in tables."
    }
  },

  "fontWeight": {
    "thin":       { "$value": 100, "$type": "fontWeight" },
    "extralight": { "$value": 200, "$type": "fontWeight" },
    "light":      { "$value": 300, "$type": "fontWeight" },
    "regular":    { "$value": 400, "$type": "fontWeight" },
    "medium":     { "$value": 500, "$type": "fontWeight" },
    "semibold":   { "$value": 600, "$type": "fontWeight" },
    "bold":       { "$value": 700, "$type": "fontWeight" },
    "extrabold":  { "$value": 800, "$type": "fontWeight" },
    "black":      { "$value": 900, "$type": "fontWeight" }
  },

  "fontSize": {
    "2xs": { "$value": "0.6875rem", "$type": "dimension" },
    "xs":  { "$value": "0.75rem",   "$type": "dimension" },
    "sm":  { "$value": "0.875rem",  "$type": "dimension" },
    "md":  { "$value": "1rem",      "$type": "dimension" },
    "lg":  { "$value": "1.125rem",  "$type": "dimension" },
    "xl":  { "$value": "1.25rem",   "$type": "dimension" },
    "2xl": { "$value": "1.5rem",    "$type": "dimension" },
    "3xl": { "$value": "1.875rem",  "$type": "dimension" },
    "4xl": { "$value": "2.25rem",   "$type": "dimension" },
    "5xl": { "$value": "3rem",      "$type": "dimension" },
    "6xl": { "$value": "3.75rem",   "$type": "dimension" },
    "7xl": { "$value": "4.5rem",    "$type": "dimension" },
    "8xl": { "$value": "6rem",      "$type": "dimension" },
    "display": { "$value": "clamp(3rem, 8vw, 7rem)", "$type": "dimension", "$description": "Fluid hero display size" }
  },

  "lineHeight": {
    "none":    { "$value": "1",    "$type": "number" },
    "tight":   { "$value": "1.1",  "$type": "number" },
    "snug":    { "$value": "1.25", "$type": "number" },
    "normal":  { "$value": "1.5",  "$type": "number" },
    "relaxed": { "$value": "1.625","$type": "number" },
    "loose":   { "$value": "2",    "$type": "number" }
  },

  "letterSpacing": {
    "tighter": { "$value": "-0.04em", "$type": "dimension", "$description": "Large display headings (TWK 600+)" },
    "tight":   { "$value": "-0.02em", "$type": "dimension" },
    "normal":  { "$value": "0",       "$type": "dimension" },
    "wide":    { "$value": "0.02em",  "$type": "dimension" },
    "wider":   { "$value": "0.05em",  "$type": "dimension", "$description": "Small-caps, overlines, labels" },
    "widest":  { "$value": "0.12em",  "$type": "dimension" }
  },

  "spacing": {
    "0":   { "$value": "0",        "$type": "dimension" },
    "px":  { "$value": "1px",      "$type": "dimension" },
    "0-5": { "$value": "0.125rem", "$type": "dimension" },
    "1":   { "$value": "0.25rem",  "$type": "dimension" },
    "2":   { "$value": "0.5rem",   "$type": "dimension" },
    "3":   { "$value": "0.75rem",  "$type": "dimension" },
    "4":   { "$value": "1rem",     "$type": "dimension" },
    "5":   { "$value": "1.25rem",  "$type": "dimension" },
    "6":   { "$value": "1.5rem",   "$type": "dimension" },
    "8":   { "$value": "2rem",     "$type": "dimension" },
    "10":  { "$value": "2.5rem",   "$type": "dimension" },
    "12":  { "$value": "3rem",     "$type": "dimension" },
    "16":  { "$value": "4rem",     "$type": "dimension" },
    "20":  { "$value": "5rem",     "$type": "dimension" },
    "24":  { "$value": "6rem",     "$type": "dimension" },
    "32":  { "$value": "8rem",     "$type": "dimension" },
    "40":  { "$value": "10rem",    "$type": "dimension" },
    "48":  { "$value": "12rem",    "$type": "dimension" },
    "64":  { "$value": "16rem",    "$type": "dimension" }
  },

  "radius": {
    "none":   { "$value": "0",      "$type": "dimension" },
    "xs":     { "$value": "2px",    "$type": "dimension" },
    "sm":     { "$value": "4px",    "$type": "dimension" },
    "md":     { "$value": "8px",    "$type": "dimension" },
    "lg":     { "$value": "12px",   "$type": "dimension" },
    "xl":     { "$value": "16px",   "$type": "dimension" },
    "2xl":    { "$value": "24px",   "$type": "dimension" },
    "3xl":    { "$value": "32px",   "$type": "dimension" },
    "full":   { "$value": "9999px", "$type": "dimension" }
  },

  "shadow": {
    "xs": { "$value": "0 1px 2px rgba(17,17,19,0.06)",                                        "$type": "shadow" },
    "sm": { "$value": "0 1px 3px rgba(17,17,19,0.08), 0 1px 2px rgba(17,17,19,0.04)",         "$type": "shadow" },
    "md": { "$value": "0 4px 6px rgba(17,17,19,0.08), 0 2px 4px rgba(17,17,19,0.04)",         "$type": "shadow" },
    "lg": { "$value": "0 10px 25px rgba(17,17,19,0.10), 0 4px 10px rgba(17,17,19,0.06)",      "$type": "shadow" },
    "xl": { "$value": "0 20px 40px rgba(17,17,19,0.14)",                                      "$type": "shadow" },
    "2xl": { "$value": "0 30px 60px rgba(17,17,19,0.20)",                                     "$type": "shadow" },
    "brand-glow": { "$value": "0 0 0 6px rgba(248,112,22,0.12), 0 8px 24px rgba(248,112,22,0.28)", "$type": "shadow", "$description": "Focus ring / CTA halo" }
  },

  "duration": {
    "instant": { "$value": "0ms",   "$type": "duration" },
    "fast":    { "$value": "150ms", "$type": "duration" },
    "base":    { "$value": "240ms", "$type": "duration" },
    "slow":    { "$value": "400ms", "$type": "duration" },
    "slower":  { "$value": "640ms", "$type": "duration" }
  },

  "easing": {
    "linear":    { "$value": "linear",                                   "$type": "cubicBezier" },
    "in":        { "$value": "cubic-bezier(0.4, 0, 1, 1)",               "$type": "cubicBezier" },
    "out":       { "$value": "cubic-bezier(0, 0, 0.2, 1)",               "$type": "cubicBezier" },
    "in-out":    { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",             "$type": "cubicBezier" },
    "emphasized":{ "$value": "cubic-bezier(0.2, 0, 0, 1)",               "$type": "cubicBezier", "$description": "Expressive, brand-feeling motion" }
  },

  "breakpoint": {
    "sm": { "$value": "640px",  "$type": "dimension" },
    "md": { "$value": "768px",  "$type": "dimension" },
    "lg": { "$value": "1024px", "$type": "dimension" },
    "xl": { "$value": "1280px", "$type": "dimension" },
    "2xl":{ "$value": "1536px", "$type": "dimension" }
  },

  "layout": {
    "container-sm":  { "$value": "640px",  "$type": "dimension" },
    "container-md":  { "$value": "768px",  "$type": "dimension" },
    "container-lg":  { "$value": "1024px", "$type": "dimension" },
    "container-xl":  { "$value": "1200px", "$type": "dimension" },
    "container-2xl": { "$value": "1440px", "$type": "dimension" },
    "reading-width": { "$value": "72ch",   "$type": "dimension" }
  },

  "z-index": {
    "base":     { "$value": 0,    "$type": "number" },
    "dropdown": { "$value": 1000, "$type": "number" },
    "sticky":   { "$value": 1020, "$type": "number" },
    "fixed":    { "$value": 1030, "$type": "number" },
    "modal-backdrop": { "$value": 1040, "$type": "number" },
    "modal":    { "$value": 1050, "$type": "number" },
    "popover":  { "$value": 1060, "$type": "number" },
    "tooltip":  { "$value": 1070, "$type": "number" },
    "toast":    { "$value": 1080, "$type": "number" }
  }
}
